# Apple Developer Account credentials for code signing and notarization
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# Your Apple ID email
APPLE_ID=your-apple-id@email.com

# App-specific password generated from appleid.apple.com
# Security > App-Specific Passwords
APPLE_ID_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Your Apple Developer Team ID
# Found at developer.apple.com/account under Membership
APPLE_TEAM_ID=2QW696JV44
